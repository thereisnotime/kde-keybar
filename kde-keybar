DEFAULT_CONFIG = {
    "position": "bottom",             # "bottom" (above OSK) or "top"
    "visibility": "keyboard",         # "keyboard" (auto-hide with OSK) or "always"
    "font_px": 20,
    "button_height_px": 54,           # thickness of the strip
    "button_min_width_px": 64,        # min key width; below this the row scrolls/wraps
    "overflow": "scroll",             # "scroll" (sideways) or "wrap" (new row)
    "gap_px": 0,                      # extra px between bar and keyboard (+ up / - down)
    "margin_px": None,                # hard override of the bottom margin; null = auto
    "keyboard_height_fraction": {"landscape": 0.30, "portrait": 0.24},
    "ydotool_socket": "/run/ydotoold.socket",
    "theme": "dark",                  # dark | light | nord | solarized | transparent | matrix
    "style": {},                      # override individual theme keys here (see README)
    "buttons": [
        {"label": "Esc",     "keys": ["ESC"]},
        {"label": "Tab",     "keys": ["TAB"]},
        {"label": "Alt+Tab", "keys": ["LALT", "TAB"]},
        {"label": "^C",      "keys": ["LCTRL", "C"]},
        {"label": "^B",      "keys": ["LCTRL", "B"]},
        {"label": "^D",      "keys": ["LCTRL", "D"]},
        {"label": "^L",      "keys": ["LCTRL", "L"]},
        {"label": "^R",      "keys": ["LCTRL", "R"]},
        {"label": "←",       "keys": ["LEFT"]},
        {"label": "↓",       "keys": ["DOWN"]},
